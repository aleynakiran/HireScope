# Gerçek backend adresi (OAuth butonları için mutlaka tam URL).
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000

# İsteğe bağlı: API’yi doğrudan bu URL’ye gönder (proxy kullanma).
# Boş bırakırsan `npm run dev` sırasında istekler `/api` üzerinden proxylanır.
# VITE_API_URL=http://127.0.0.1:8000

# Proxy hedefi (varsayılan 8000):
# VITE_PROXY_TARGET=http://127.0.0.1:8000
