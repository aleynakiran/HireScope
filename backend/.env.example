DATABASE_URL=sqlite:///./hirescope.db
SECRET_KEY=change-this-to-a-real-256-bit-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
TEMP_TOKEN_EXPIRE_MINUTES=5
# Comma-separated SPA origins for CORS. Leave unset in dev to allow both:
# http://localhost:5173 and http://127.0.0.1:5173
# FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
BOOTSTRAP_ADMIN_EMAIL=
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/oauth/github/callback
